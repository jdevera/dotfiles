# Status configuration {{ "{{{" }}
# ========================

{{- $t := .tmux.theme -}}
{{- $g := .tmux.glyphs }}

# Update the status bar every interval seconds.  By default, updates will occur
# every 15 seconds.  A setting of zero disables redrawing at interval.
set  -g status-interval 5

# Set the position of the window list component of the status line: left,
# centre or right justified.
set  -g status-justify centre

set  -g status-style "bg={{ $t.status_bg }} fg={{ $t.status_fg }}"

# Status left
# -----------
set  -g status-left-length 40
# Command mode indicator:
set  -g status-left "#{?client_prefix,#[bg={{ $t.prefix_bg }}#,fg={{ $t.prefix_fg }}#,bold] {{ $g.icon_prefix }} #[bg={{ $t.hostname_bg }}#,fg={{ $t.prefix_bg }}#,nobold]{{ $g.sep_right }} ,}"
# Hostname:
set -ag status-left "#[bg={{ $t.hostname_bg }},fg={{ $t.hostname_fg }}] {{ $g.icon_hostname }} #h #[bg={{ $t.session_bg }},fg={{ $t.hostname_bg }}]{{ $g.sep_right }} "
# Session name:
set -ag status-left "#[bg={{ $t.session_bg }},fg={{ $t.session_fg }}] {{ $g.icon_session }} #S #[bg={{ $t.status_bg }},fg={{ $t.session_bg }}]{{ $g.sep_right }}"

# Status right
# ------------
set  -g status-right-length 55
set  -g status-right ''

# Percentage of RAM in use
set -ag status-right "#[bg={{ $t.status_bg }},fg={{ $t.ram_bg }}]{{ $g.sep_left }}#[bg={{ $t.ram_bg }},fg={{ $t.ram_fg }}] {{ $g.icon_ram }} #(~/.tmux_scripts/used_ram_pct) #[bg={{ $t.ram_bg }},fg={{ $t.cpu_bg }}]{{ $g.sep_left }}"
# CPU usage
set -ag status-right "#[bg={{ $t.cpu_bg }},fg={{ $t.cpu_fg }}] {{ $g.icon_cpu }} #(~/.tmux_scripts/cpu_pct) #[bg={{ $t.cpu_bg }},fg={{ $t.time_bg }}]{{ $g.sep_left }}"
# Time
set -ag status-right "#[bg={{ $t.time_bg }},fg={{ $t.time_fg }}] {{ $g.icon_time }} %d/%m %H:%M"
# Connectivity warning (only shown when offline)
set -ag status-right "#(~/.tmux_scripts/net_check)"

# Windows Status
# --------------

setw -g window-status-current-format '#[fg={{ $t.win_current_accent }},bold](#[fg={{ $t.win_current_fg }},bold]#I:#W#F#[fg={{ $t.win_current_accent }},bold])#[fg=default,default]'
setw -g window-status-current-style bright
setw -g window-status-style fg={{ $t.win_fg }}
setw -g window-status-last-style fg={{ $t.win_last_fg }}
setw -g window-status-activity-style fg={{ $t.win_activity_fg }},bold
setw -g window-status-bell-style fg={{ $t.win_activity_fg }},bold

# }}}
# Mouse configuration {{ "{{{" }}
# =======================

# Enable mouse support: scroll to enter copy mode, click to select panes/windows,
# drag to resize panes. Works over SSH.
set -g mouse on



# }}}
# Other Config {{ "{{{" }}
# ================

# Set the base index from which an unused index should be searched when a new
# window is created.
set -g base-index 1
set -g pane-base-index 1

{{ if not .is_macos -}}
{{/*
# aggresive-resize is helpful but in macos, when using iTerm2 with the Tmux
# integration, you get an error if the option is on:
#
# -----------------------
# Unsupported tmux option
# ---------------------------------------------------------------------------
# The "aggressive-resize" option is turned on in tmux. It is not compatible
# with the iTerm2-tmux integration. Please disable it and try again.
# ---------------------------------------------------------------------------
#
# I does not seem like it will be changed:
# https://gitlab.com/gnachman/iterm2/-/issues/2585
#
# */ -}}
setw -g aggressive-resize on
{{- end }}

# Do not wrap on searches (I added this feature :D )
setw -g wrap-search off

# Set the maximum number of lines held in window history.  This setting applies
# only to new windows - existing window histories are not resized and retain
# the limit at the point they were created.
set -g history-limit 50000

# Set the default terminal for new windows created in this session - the
# default value of the TERM environment variable.  For tmux to work correctly,
# this must be set to 'screen' or a derivative of it.
set -g default-terminal "screen-256color"

# Enable truecolor where available
set-option -ga terminal-overrides ",xterm-256color:Tc"

# Allow modified key sequences (like Shift+Enter) to pass through to
# applications instead of being swallowed by tmux. Without this, tmux treats
# Shift+Enter the same as Enter, breaking apps that rely on the distinction
# (e.g. Claude Code uses Shift+Enter for newline vs Enter for submit).
set -s extended-keys always

# Use the CSI u encoding for extended keys (e.g. ESC[13;2u for Shift+Enter)
# instead of the default xterm modifyOtherKeys format (ESC[27;2;13~), which
# apps like Claude Code don't recognise.
set -s extended-keys-format csi-u

# Tell tmux that the outer terminal supports extended keys, so tmux knows it
# can forward CSI u-encoded sequences from the terminal.
set -as terminal-features 'xterm*:extkeys'

# }}}
# Key Bindings {{ "{{{" }}
# ===============

# Okay, I admit that C-a is more confortable than C-b as client prefix
# --------------------------------------------------------------------
unbind C-b
set-option -g prefix C-a
bind-key C-a send-prefix


# Bind the r key to reload this file
bind-key r source-file ~/.config/tmux/tmux.conf

# Use Vim-like keys to resize panes
unbind-key C-Left;  bind-key -r < resize-pane -L 1
unbind-key C-Right; bind-key -r > resize-pane -R 1
unbind-key C-Up;    bind-key -r + resize-pane -U 1
unbind-key C-Down;  bind-key -r - resize-pane -D 1

# Use Vim-like keys to switch panes
unbind-key Up;      bind-key -r k select-pane -U
unbind-key Down;    bind-key -r j select-pane -D
unbind-key Left;    bind-key -r h select-pane -L
unbind-key Right;   bind-key -r l select-pane -R

# Use | and _ for vertical and horizontal splits
unbind-key '"'
bind-key _ split-window    -c "#{pane_current_path}"

unbind-key %
bind-key | split-window -h -c "#{pane_current_path}"

# Use Vim-like keys to start selection, copy it and paste it
# unbind p
# bind p paste-buffer
bind-key -T copy-mode-vi v send-keys -X begin-selection
bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "{{ .copy_command }}"

# Send all history to a file
bind-key P command-prompt -p 'save history to filename:' -I '~/.tmux.history' 'capture-pane -S -32768 ; save-buffer %1 ; delete-buffer'

# Use b to go to the last active window
bind-key b last

# Window picker with fzf in a floating popup
bind-key f display-popup -E -w 60% -h 60% "~/.config/tmux/window-picker.sh"

# }}}
# Plugins {{ "{{{" }}
# =========

# List of TPM plugins
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'wfxr/tmux-fzf-url'

# Initialize TPM (keep this line at the very bottom of tmux.conf)
run '~/.tmux/plugins/tpm/tpm'

# }}}
