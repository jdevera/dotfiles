# Path bookmarks managed by dotfiles
# Generated from .chezmoidata/path_bookmarks.yaml
# Sourced by 196_tool_path_bookmarks.{sh,zsh}

{{ range .path_bookmarks -}}
{{ if or (not (hasKey . "os")) (eq .os $.chezmoi.os) -}}
{{ if hasPrefix "/" .path -}}
bookmark {{ .name }} "{{ .path }}"
{{ else -}}
bookmark {{ .name }} "$HOME/{{ .path }}"
{{ end -}}
{{ end -}}
{{ end -}}
