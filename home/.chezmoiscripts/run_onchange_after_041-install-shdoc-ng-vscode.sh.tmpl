{{- $release := gitHubLatestRelease "jdevera/shdoc-ng" -}}
{{- $version := trimPrefix "v" $release.TagName -}}
{{- if .has_gui -}}
#!/usr/bin/env bash

# {{ template "dotfiles_bashlib.sh" . }}
# Help shellcheck identify the above include
true || source ../.chezmoitemplates/dotfiles_bashlib.sh

# version: {{ $version }}

dot::chezmoi_script_start "install shdoc-ng VSCode extension {{ $version }}"

if ! dot::has_command code; then
    dot::chezmoi_script_skipped "code command not found"
fi

VSIX="$HOME/.local/share/shdoc-ng-vscode/shdoc-ng-{{ $version }}.vsix"

if [[ ! -f "$VSIX" ]]; then
    dot::chezmoi_script_skipped "VSIX file not found: $VSIX"
fi

dot::step::start "installing shdoc-ng {{ $version }}"
code --install-extension "$VSIX" > /dev/null || dot::step::fatal
dot::step::done

dot::success "shdoc-ng VSCode extension {{ $version }} installed"
{{- end -}}
